# ===== Binance API 配置 =====
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# ===== 定投配置 =====
# 交易对列表，逗号分隔，例如: BTCUSDT,ETHUSDT,SOLUSDT
TRADE_PAIRS=BTCUSDT,ETHUSDT
# 每个交易对对应的买入金额(USDT)，逗号分隔，与 TRADE_PAIRS 一一对应
TRADE_AMOUNTS=10,5
# 定投时间 (cron 表达式，默认每天北京时间 09:00)
# 秒 分 时 日 月 周
CRON_SCHEDULE=0 0 9 * * *
# 时区，默认 Asia/Shanghai
TIMEZONE=Asia/Shanghai

# ===== Telegram 通知配置 =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===== 代理配置 (可选) =====
# 如果需要通过代理访问 Binance/Telegram API，取消注释并填写
# 支持 HTTP_PROXY / HTTPS_PROXY / ALL_PROXY
# Go net/http 会自动读取这些环境变量
#HTTPS_PROXY=http://127.0.0.1:7890
#HTTP_PROXY=http://127.0.0.1:7890
#NO_PROXY=localhost,127.0.0.1

# ===== 可选配置 =====
# 是否使用模拟交易模式 (true/false)
# 对应 demo.binance.com，API 地址: https://demo-api.binance.com
# 需在 https://demo.binance.com/en/my/settings/api-management 创建 API Key
USE_DEMO=false
# 是否使用测试网 (true/false)，对应 testnet.binance.vision（与 demo 不同）
USE_TESTNET=false
# 自定义 API 地址（最高优先级，覆盖 USE_DEMO 和 USE_TESTNET）
#BINANCE_BASE_URL=https://demo-api.binance.com
# 自动与活期理财互转 (true/false)
# 开启后：余额不足自动从活期理财赎回 USDT，交易后自动将资产存入活期理财
AUTO_EARN=false
# 日志级别 (debug/info/warn/error)
LOG_LEVEL=info
