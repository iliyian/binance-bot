# ===== Binance API 配置 =====
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Demo 专用 API Key（可选，USE_DEMO=true 时优先使用，未配置则 fallback 到上方密钥）
# 需在 https://demo.binance.com/en/my/settings/api-management 创建
#BINANCE_DEMO_API_KEY=your_demo_api_key_here
#BINANCE_DEMO_SECRET_KEY=your_demo_secret_key_here

# ===== 定投配置 =====
# 交易对列表，逗号分隔，例如: BTCUSDT,ETHUSDT,SOLUSDT
TRADE_PAIRS=BTCUSDT,ETHUSDT
# 每个交易对对应的买入金额(USDT)，逗号分隔，与 TRADE_PAIRS 一一对应
TRADE_AMOUNTS=10,5
# 是否启用定投定时任务 (true/false)
DCA_ENABLED=true
# 定投时间 (cron 表达式，默认每天北京时间 09:00)
# 秒 分 时 日 月 周
CRON_SCHEDULE=0 0 9 * * *
# 时区，默认 Asia/Shanghai
TIMEZONE=Asia/Shanghai

# ===== Telegram 通知配置 =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===== 代理配置 (可选) =====
# 如果需要通过代理访问 Binance/Telegram API，取消注释并填写
# 支持 HTTP_PROXY / HTTPS_PROXY / ALL_PROXY
# Go net/http 会自动读取这些环境变量
#HTTPS_PROXY=http://127.0.0.1:7890
#HTTP_PROXY=http://127.0.0.1:7890
#NO_PROXY=localhost,127.0.0.1

# ===== 可选配置 =====
# 是否使用模拟交易模式 (true/false)
# 对应 demo.binance.com，API 地址: https://demo-api.binance.com
USE_DEMO=false
# 自定义 API 地址（最高优先级，覆盖 USE_DEMO）
#BINANCE_BASE_URL=https://demo-api.binance.com
# 自动与活期理财互转 (true/false)
# 开启后：余额不足自动从活期理财赎回 USDT，交易后自动将资产存入活期理财
AUTO_EARN=false
# 日志级别 (debug/info/warn/error)
LOG_LEVEL=info

# ===== Pool 配置 (可选) =====
# 每个交易对的初始 Pool 金额(USDT)，逗号分隔，与 TRADE_PAIRS 一一对应
# 由于币安有最小交易金额限制，每次定投实际花费可能小于设定金额
# Pool 会自动累积差额，并在下次定投时加上，确保长期不丢失任何资金
# 重启后需手动设置此值以恢复之前累积的 Pool（查看最近一次 Telegram 通知中的 Pool 值）
#POOL_AMOUNTS=0.5,0.3

# ===== 布林带价格监控配置 (可选) =====
# 是否启用布林带价格监控 (true/false)
BOLL_MONITOR_ENABLED=false
# 监控的永续合约交易对，逗号分隔
# 格式1: 每个交易对单独指定 K 线级别，用 : 分隔交易对和级别，级别间用 & 连接
#   BTCUSDT:1h&4h,ETHUSDT:15m&1h
# 格式2: 所有交易对使用统一 K 线级别（需配合 BOLL_MONITOR_INTERVALS）
#   BTCUSDT,ETHUSDT
# 注: 用 & 连接的多个级别表示"所有级别都突破才触发提醒"
#BOLL_MONITOR_SYMBOLS=BTCUSDT:1h&4h,ETHUSDT:15m&1h
# 全局默认 K 线级别（当 BOLL_MONITOR_SYMBOLS 中未指定级别时使用）
#BOLL_MONITOR_INTERVALS=1h&4h
# 布林带周期 (默认 20)
#BOLL_MONITOR_PERIOD=20
# 布林带标准差倍数 (默认 2.0)
#BOLL_MONITOR_STDDEV=2
# 检查间隔 (默认 1m，支持 30s, 1m, 5m 等格式)
#BOLL_MONITOR_CHECK_INTERVAL=1m
